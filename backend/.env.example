# Anthropic API Key (bắt buộc)
ANTHROPIC_API_KEY=your-anthropic-api-key-here

# Serper.dev — Google Search API (FREE 2500 queries)
# Đăng ký: https://serper.dev → Dashboard → copy API key
SERPER_API_KEY=your-serper-api-key-here

# Google Custom Search API (backup — FREE 100 queries/ngày)
GOOGLE_SEARCH_API_KEY=your-google-api-key-here
GOOGLE_SEARCH_CX=your-search-engine-cx-id-here

# Firebase Realtime Database URL
FIREBASE_DB_URL=https://your-project-default-rtdb.firebasedatabase.app

# Server Port
PORT=3000
