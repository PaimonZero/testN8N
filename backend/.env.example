# Anthropic API Key (Claude 3 Haiku)
ANTHROPIC_API_KEY=your-anthropic-api-key-here

# Google Gemini API Key (Gemini 2.5 Flash)
GEMINI_API_KEY=your-gemini-api-key-here

# Serper.dev — Google Search API (FREE 2500 queries)
SERPER_API_KEY=your-serper-api-key-here

# Mapbox Geocoding API
MAPBOX_API_KEY=your-mapbox-api-key-here

# Google Custom Search API (backup)
GOOGLE_SEARCH_API_KEY=your-google-api-key-here
GOOGLE_SEARCH_CX=your-search-engine-cx-id-here

# Firebase Realtime Database URL
FIREBASE_DB_URL=https://your-project-default-rtdb.firebasedatabase.app

# Admin unlock code for Claude Haiku rate limit bypass
ADMIN_UNLOCK_CODE=wewillwin100

# Server Port
PORT=3000

# Set to true to log full LLM prompts/responses (dev only)
DEBUG_LLM=false
